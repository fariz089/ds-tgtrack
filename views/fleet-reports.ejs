<link rel="stylesheet" href="/css/dashboard.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.min.css" />
<style>
  .report-header { background: linear-gradient(135deg, #003d5c 0%, #0066a1 100%); color: white; padding: 24px 28px; border-radius: 10px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; }
  .report-title { font-size: 22px; font-weight: 700; }
  .report-subtitle { font-size: 13px; opacity: 0.85; margin-top: 4px; }
  .report-actions { display: flex; gap: 10px; }
  .btn-report { padding: 10px 20px; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 13px; display: flex; align-items: center; gap: 6px; transition: all 0.2s; }
  .btn-print { background: white; color: #003d5c; }
  .btn-print:hover { background: #f0f4f8; }

  .report-filters { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 24px; display: flex; gap: 15px; align-items: end; flex-wrap: wrap; }
  .filter-group label { font-size: 12px; font-weight: 600; color: #64748b; display: block; margin-bottom: 5px; }
  .filter-group select, .filter-group input { padding: 9px 12px; border: 2px solid #e5e7eb; border-radius: 6px; font-size: 13px; }
  .btn-generate { padding: 10px 22px; background: linear-gradient(135deg, #0066a1 0%, #003d5c 100%); color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 13px; }

  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin-bottom: 24px; }
  .stat-card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); text-align: center; }
  .stat-value { font-size: 28px; font-weight: 700; }
  .stat-label { font-size: 12px; color: #64748b; margin-top: 4px; }

  .report-section { background: white; padding: 24px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); margin-bottom: 24px; }
  .section-title { font-size: 16px; font-weight: 700; color: #003d5c; margin: 0 0 16px 0; display: flex; align-items: center; gap: 8px; }

  .vehicle-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .vehicle-table th { background: #f8fafc; padding: 10px 12px; text-align: left; color: #64748b; font-weight: 600; border-bottom: 2px solid #e5e7eb; }
  .vehicle-table td { padding: 10px 12px; border-bottom: 1px solid #f1f5f9; }
  .vehicle-table tr:hover { background: #f8fafc; }

  .score-badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-weight: 700; font-size: 12px; }
  .severity-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 4px; }

  .chart-container { position: relative; height: 280px; margin-top: 12px; }

  .alarm-type-bar { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
  .alarm-type-name { min-width: 220px; font-size: 12px; color: #374151; text-align: right; }
  .alarm-type-fill { height: 22px; border-radius: 4px; background: linear-gradient(90deg, #0066a1, #38bdf8); min-width: 2px; transition: width 0.5s ease; }
  .alarm-type-count { font-size: 12px; font-weight: 600; color: #64748b; min-width: 30px; }

  @media print {
    .sidebar, .topbar, .report-filters, .report-actions, .btn-generate { display: none !important; }
    .main-content { margin-left: 0 !important; padding: 0 !important; }
    .report-header { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
    .stat-card, .report-section { break-inside: avoid; }
    .score-badge { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
  }
</style>

<div class="report-header">
  <div>
    <div class="report-title"><i class="fas fa-file-alt"></i> Fleet Safety Report</div>
    <div class="report-subtitle" id="reportPeriod">Gilang Sembilan Sembilan — Fleet Management System</div>
  </div>
  <div class="report-actions">
    <button class="btn-report btn-print" onclick="window.print()">
      <i class="fas fa-print"></i> Print Report
    </button>
  </div>
</div>

<div class="report-filters">
  <div class="filter-group">
    <label><i class="fas fa-clock"></i> Time Range</label>
    <select id="reportHours">
      <option value="1">Last 1 Hour</option>
      <option value="3">Last 3 Hours</option>
      <option value="5">Last 5 Hours</option>
      <option value="24" selected>Last 24 Hours</option>
      <option value="72">Last 3 Days</option>
      <option value="168">Last 7 Days</option>
      <option value="720">Last 30 Days</option>
    </select>
  </div>
  <div class="filter-group">
    <label><i class="fas fa-truck"></i> Vehicle</label>
    <select id="reportVehicle">
      <option value="all">All Vehicles</option>
      <% vehicles.forEach(v => { %>
        <option value="<%= v %>"><%= v %></option>
      <% }); %>
    </select>
  </div>
  <button class="btn-generate" onclick="generateReport()">
    <i class="fas fa-chart-bar"></i> Generate Report
  </button>
</div>

<!-- Summary Stats -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-value" id="rptScore" style="color: #0066a1;">--</div>
    <div id="rptGrade" style="font-size: 14px; font-weight: 600;">--</div>
    <div class="stat-label">Fleet Safety Score</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="rptVehicles" style="color: #16a34a;">--</div>
    <div class="stat-label">Active Vehicles</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="rptTotal" style="color: #f59e0b;">--</div>
    <div class="stat-label">Total Alarms</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="rptCritical" style="color: #ef4444;">--</div>
    <div class="stat-label">Critical Events</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="rptADAS" style="color: #8b5cf6;">--</div>
    <div class="stat-label">ADAS Events</div>
  </div>
  <div class="stat-card">
    <div class="stat-value" id="rptDSM" style="color: #06b6d4;">--</div>
    <div class="stat-label">DSM Events</div>
  </div>
</div>

<!-- Vehicle Performance Table -->
<div class="report-section">
  <h3 class="section-title"><i class="fas fa-car" style="color: #0066a1;"></i> Vehicle Performance Ranking</h3>
  <table class="vehicle-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Vehicle</th>
        <th>Score</th>
        <th>Total Alarms</th>
        <th>Critical</th>
        <th>High</th>
        <th>Medium</th>
        <th>Low</th>
        <th>ADAS</th>
        <th>DSM</th>
      </tr>
    </thead>
    <tbody id="vehicleTableBody">
      <tr><td colspan="10" style="text-align: center; color: #94a3b8; padding: 40px;">Click "Generate Report" to load data</td></tr>
    </tbody>
  </table>
</div>

<!-- Alarm Type Breakdown -->
<div class="report-section">
  <h3 class="section-title"><i class="fas fa-exclamation-triangle" style="color: #f59e0b;"></i> Alarm Type Breakdown</h3>
  <div id="alarmBreakdown">
    <div style="text-align: center; color: #94a3b8; padding: 30px;">No data</div>
  </div>
</div>

<!-- Category Chart -->
<div class="report-section">
  <h3 class="section-title"><i class="fas fa-chart-pie" style="color: #8b5cf6;"></i> Alarm Category Distribution</h3>
  <div class="chart-container">
    <canvas id="categoryChart"></canvas>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
let categoryChart = null;

async function generateReport() {
  const hours = document.getElementById('reportHours').value;
  const vehicle = document.getElementById('reportVehicle').value;

  document.getElementById('reportPeriod').textContent = 
    `Report Period: Last ${hours} hour(s) — Generated ${new Date().toLocaleString('id-ID')}`;

  try {
    // Fetch fleet score
    const scoreResp = await fetch(`/api/safety/fleet-score?hours=${hours}`);
    const scoreData = await scoreResp.json();

    document.getElementById('rptScore').textContent = scoreData.score;
    document.getElementById('rptScore').style.color = scoreData.grade.color;
    document.getElementById('rptGrade').textContent = `${scoreData.grade.letter} - ${scoreData.grade.label}`;
    document.getElementById('rptGrade').style.color = scoreData.grade.color;
    document.getElementById('rptVehicles').textContent = scoreData.total_vehicles;
    document.getElementById('rptTotal').textContent = scoreData.total_alarms;
    document.getElementById('rptCritical').textContent = scoreData.severity_counts.critical;
    document.getElementById('rptADAS').textContent = scoreData.category_breakdown.ADAS;
    document.getElementById('rptDSM').textContent = scoreData.category_breakdown.DSM;

    // Fetch risky vehicles (all of them)
    const riskyResp = await fetch(`/api/safety/risky-vehicles?hours=${hours}&limit=50`);
    const riskyData = await riskyResp.json();

    // Build vehicle table
    const tbody = document.getElementById('vehicleTableBody');
    if (riskyData.length === 0) {
      tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;color:#94a3b8;padding:30px;">No alarm data for this period</td></tr>';
    } else {
      // Sort by score ascending (worst first)
      riskyData.sort((a, b) => a.score - b.score);
      tbody.innerHTML = riskyData.map((v, i) => `
        <tr>
          <td style="font-weight:600;color:#64748b;">${i + 1}</td>
          <td style="font-weight:600;">${v.vehicle_name}</td>
          <td><span class="score-badge" style="background:${v.grade.color}20;color:${v.grade.color};">${v.score} ${v.grade.letter}</span></td>
          <td>${v.alarm_count}</td>
          <td><span style="color:#ef4444;font-weight:600;">${v.severity_counts.critical}</span></td>
          <td><span style="color:#f97316;">${v.severity_counts.high}</span></td>
          <td><span style="color:#f59e0b;">${v.severity_counts.medium}</span></td>
          <td><span style="color:#84cc16;">${v.severity_counts.low}</span></td>
          <td>${v.category_breakdown.ADAS}</td>
          <td>${v.category_breakdown.DSM}</td>
        </tr>
      `).join('');
    }

    // Fetch alarm statistics
    const statsResp = await fetch(`/api/safety/alarm-statistics?hours=${hours}`);
    const statsData = await statsResp.json();

    // Build alarm type breakdown bars
    const maxCount = statsData.length > 0 ? statsData[0].count : 1;
    const breakdownEl = document.getElementById('alarmBreakdown');
    if (statsData.length === 0) {
      breakdownEl.innerHTML = '<div style="text-align:center;color:#94a3b8;padding:30px;">No alarm data</div>';
    } else {
      breakdownEl.innerHTML = statsData.map(a => `
        <div class="alarm-type-bar">
          <div class="alarm-type-name">${a.alarm_type}</div>
          <div class="alarm-type-fill" style="width:${Math.max(2, (a.count / maxCount) * 100)}%;"></div>
          <div class="alarm-type-count">${a.count}</div>
        </div>
      `).join('');
    }

    // Build category chart
    if (categoryChart) categoryChart.destroy();
    const ctx = document.getElementById('categoryChart').getContext('2d');
    const catData = scoreData.category_breakdown;
    categoryChart = new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: ['ADAS', 'DSM', 'FM', 'BSD'],
        datasets: [{
          data: [catData.ADAS || 0, catData.DSM || 0, catData.FM || 0, catData.BSD || 0],
          backgroundColor: ['#8b5cf6', '#06b6d4', '#f59e0b', '#22c55e'],
          borderWidth: 2,
          borderColor: '#fff',
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { position: 'right', labels: { font: { size: 13 }, padding: 16 } },
        },
      },
    });

  } catch (err) {
    console.error('Report generation error:', err);
  }
}

// Auto-generate on load
document.addEventListener('DOMContentLoaded', generateReport);
</script>
