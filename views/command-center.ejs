<!-- Additional CSS -->
<link rel="stylesheet" href="/css/command-center.css" />

<div class="command-center-container">
  <!-- Header Stats -->
  <div class="stats-bar">
    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #0066a1 0%, #003d5c 100%)">
        <i class="fas fa-truck"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value" id="totalVehicles">0</div>
        <div class="stat-label">Total Vehicles</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%)">
        <i class="fas fa-exclamation-triangle"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value" id="totalAlarms">0</div>
        <div class="stat-label">Total Alarms (36h)</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%)">
        <i class="fas fa-shield-alt"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value" id="avgScore">0</div>
        <div class="stat-label">Avg Safety Score</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%)">
        <i class="fas fa-clock"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value">36h</div>
        <div class="stat-label">Time Range</div>
      </div>
    </div>
  </div>

  <!-- Vehicle Grid -->
  <div class="vehicle-grid" id="vehicleGrid">
    <!-- Will be populated by JavaScript -->
  </div>

  <!-- Google Maps -->
  <div class="map-container">
    <h3 style="margin: 0 0 15px 0; display: flex; align-items: center; gap: 10px">
      <i class="fas fa-map-marked-alt" style="color: #0066a1"></i>
      <span id="mapTitle">Fleet Tracking</span>
    </h3>
    <div id="map" style="width: 100%; height: 500px; border-radius: 8px"></div>
  </div>
</div>

<!-- Vehicle Detail Modal -->
<div id="vehicleModal" class="vehicle-modal">
  <div class="vehicle-modal-content">
    <div class="vehicle-modal-header">
      <h3 id="modalVehicleName">Vehicle Details</h3>
      <button class="modal-close" onclick="closeVehicleModal()">&times;</button>
    </div>
    <div class="vehicle-modal-body">
      <!-- Camera Preview -->
      <div class="camera-section">
        <h4><i class="fas fa-video"></i> Live Camera Feed</h4>
        <div class="camera-grid-modal" id="cameraGridModal">
          <!-- Will be populated -->
        </div>
      </div>

      <!-- Alarms List -->
      <div class="alarms-section">
        <h4><i class="fas fa-bell"></i> Alarms (Last 36 Hours)</h4>
        <div class="alarms-tabs">
          <button class="alarm-tab active" onclick="switchAlarmTab('all')">All</button>
          <button class="alarm-tab" onclick="switchAlarmTab('adas')">ADAS</button>
          <button class="alarm-tab" onclick="switchAlarmTab('dsm')">DSM</button>
          <button class="alarm-tab" onclick="switchAlarmTab('pending')">Pending Review</button>
        </div>
        <div id="alarmsList" class="alarms-list">
          <!-- Will be populated -->
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Video Player Modal -->
<div id="videoModal" class="video-modal">
  <div class="video-modal-content">
    <span class="video-close" onclick="closeVideo()">&times;</span>
    <video id="videoPlayer" class="video-player" controls></video>
    <div class="video-info" id="videoInfo">Loading...</div>
  </div>
</div>

<div id="imageModal" class="video-modal">
  <div class="video-modal-content">
    <span class="video-close" onclick="closeImage()">&times;</span>
    <img id="imagePreview" class="video-player" style="object-fit: contain" alt="Alarm Evidence" />
    <div class="video-info" id="imageInfo">Loading...</div>
  </div>
</div>

<!-- Scripts -->
<script src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>&callback=initMap" async defer></script>
<!-- mpegts.js: successor to flv.js, supports FLV + MPEG-TS + low-latency -->
<script src="https://cdn.jsdelivr.net/npm/mpegts.js@1.7.3/dist/mpegts.js"></script>
<!-- HLS.js: pre-loaded for M3U8/HLS streams (Chrome/Firefox) -->
<script src="https://cdn.jsdelivr.net/npm/hls.js@1.5.7/dist/hls.min.js"></script>
<!-- JMuxer: for SoloFleet H.264 WebSocket streams -->
<script src="https://cdn.jsdelivr.net/npm/jmuxer@2.0.5/dist/jmuxer.min.js"></script>
<script src="/js/command-center.js"></script>
