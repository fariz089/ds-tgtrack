<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> - Gilang Sembilan Sembilan</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/layout.css" />
  </head>
  <body>
    <div class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="sidebar-logo-wrapper">
          <div class="sidebar-logo">
            <div class="sidebar-logo-text">
              <div>GILANG SEMBILAN</div>
              <div>SEMBILAN</div>
            </div>
          </div>
          <div class="sidebar-subtitle">Fleet Management System</div>
        </div>
        <button class="toggle-sidebar" onclick="toggleSidebar()">
          <i class="fas fa-chevron-left"></i>
        </button>
      </div>
      <div class="sidebar-menu">
        <div class="menu-section-title">Main Menu</div>
        <a href="/" class="menu-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
          <i class="fas fa-chart-line"></i>
          <span>Dashboard</span>
          <span class="menu-item-tooltip">Dashboard</span>
        </a>
        <a href="/adas" class="menu-item <%= currentPage === 'adas' ? 'active' : '' %>">
          <i class="fas fa-car-crash"></i>
          <span>ADAS Monitoring</span>
          <span class="menu-item-tooltip">ADAS Monitoring</span>
        </a>
        <a href="/dsm" class="menu-item <%= currentPage === 'dsm' ? 'active' : '' %>">
          <i class="fas fa-user-shield"></i>
          <span>DSM Monitoring</span>
          <span class="menu-item-tooltip">DSM Monitoring</span>
        </a>

        <div class="menu-section-title">Reports</div>
        <a href="#" class="menu-item">
          <i class="fas fa-file-alt"></i>
          <span>Fleet Reports</span>
          <span class="menu-item-tooltip">Fleet Reports</span>
        </a>
        <a href="#" class="menu-item">
          <i class="fas fa-download"></i>
          <span>Export Data</span>
          <span class="menu-item-tooltip">Export Data</span>
        </a>
      </div>
    </div>

    <div class="main-content">
      <div class="topbar">
        <div class="topbar-title"><%= title %></div>
        <div class="filter-group">
          <label>Vehicle:</label>
          <select id="vehicleSelect" class="form-select-sm" onchange="filterByVehicle()" style="width: 200px">
            <option value="all">All Vehicles</option>
            <% if (typeof vehicles !== 'undefined' && vehicles.length > 0) { %> <% vehicles.forEach(vehicle => { %>
            <option value="<%= vehicle %>"><%= vehicle %></option>
            <% }); %> <% } %>
          </select>
          <label>Week:</label>
          <select class="form-select-sm" style="width: 150px">
            <option>Week 46 (2025)</option>
            <option>Week 45 (2025)</option>
            <option>Week 44 (2025)</option>
          </select>
          <button class="btn btn-primary btn-sm" onclick="loadData()"><i class="fas fa-sync-alt"></i> Refresh</button>
        </div>
      </div>

      <div class="content"><%- body %></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/layout.js"></script>
  </body>
</html>
