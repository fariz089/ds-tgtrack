<!-- Additional CSS for this page -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css" />
<link rel="stylesheet" href="/css/datatable-modern.css" />
<link rel="stylesheet" href="/css/file-preview.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

<!-- Filter Section -->
<div class="filter-container" style="margin-bottom: 25px;">
  <div class="filter-body" style="background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
    <div style="display: flex; gap: 15px; align-items: end; flex-wrap: wrap;">
      
      <div>
        <label style="font-size: 13px; font-weight: 600; margin-bottom: 5px; display: block; color: #374151;">
          <i class="fas fa-truck" style="color: #f59e0b;"></i> Vehicle
        </label>
        <select id="vehicleFilter" style="padding: 10px 14px; border: 2px solid #e5e7eb; border-radius: 6px; min-width: 220px; font-size: 14px; cursor: pointer;" onchange="onVehicleChange()">
          <option value="all">All Vehicles</option>
          <% vehicles.forEach(vehicle => { %>
            <option value="<%= vehicle %>"><%= vehicle %></option>
          <% }); %>
        </select>
      </div>
      
      <div>
        <label style="font-size: 13px; font-weight: 600; margin-bottom: 5px; display: block; color: #374151;">
          <i class="fas fa-clock" style="color: #f59e0b;"></i> Time Range
        </label>
        <select id="hoursFilter" style="padding: 10px 14px; border: 2px solid #e5e7eb; border-radius: 6px; font-size: 14px; cursor: pointer;" onchange="onTimeRangeChange()">
          <option value="1">Last 1 Hour</option>
          <option value="3">Last 3 Hours</option>
          <option value="5">Last 5 Hours</option>
          <option value="24" selected>Last 24 Hours</option>
          <option value="72">Last 3 Days</option>
          <option value="168">Last 7 Days</option>
          <option value="720">Last 30 Days</option>
          <option value="custom">Custom Range</option>
        </select>
      </div>

      <!-- Custom Date Range -->
      <div id="customDateRange" style="display: none; gap: 8px; align-items: end;">
        <div>
          <label style="font-size: 12px; font-weight: 600; margin-bottom: 4px; display: block; color: #6b7280;">From</label>
          <input type="text" id="startDate" placeholder="Start date" style="padding: 10px 12px; border: 2px solid #e5e7eb; border-radius: 6px; font-size: 13px; width: 160px;" />
        </div>
        <div>
          <label style="font-size: 12px; font-weight: 600; margin-bottom: 4px; display: block; color: #6b7280;">To</label>
          <input type="text" id="endDate" placeholder="End date" style="padding: 10px 12px; border: 2px solid #e5e7eb; border-radius: 6px; font-size: 13px; width: 160px;" />
        </div>
      </div>
      
      <button onclick="applyFilter()" style="padding: 10px 24px; background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%); color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 14px; box-shadow: 0 2px 8px rgba(245,158,11,0.3); transition: all 0.2s;">
        <i class="fas fa-filter"></i> Apply Filter
      </button>
      
      <button onclick="refreshTable()" style="padding: 10px 24px; background: #0066a1; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 14px; transition: all 0.2s;">
        <i class="fas fa-sync-alt"></i> Refresh
      </button>
      
      <button onclick="exportData()" style="padding: 10px 24px; background: #22c55e; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 14px; transition: all 0.2s;">
        <i class="fas fa-file-excel"></i> Export
      </button>
      
    </div>

    <!-- Data Availability Bar -->
    <div id="dataAvailability" style="margin-top: 15px; display: none;">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
        <i class="fas fa-database" style="color: #6b7280; font-size: 12px;"></i>
        <span style="font-size: 12px; font-weight: 600; color: #6b7280;">Data Availability</span>
        <span id="dataRangeInfo" style="font-size: 11px; color: #9ca3af;"></span>
      </div>
      <div id="availabilityGrid" style="display: flex; gap: 2px; flex-wrap: wrap;"></div>
      <div style="display: flex; gap: 12px; margin-top: 6px;">
        <span style="font-size: 11px; color: #9ca3af;"><span style="display:inline-block;width:10px;height:10px;background:#22c55e;border-radius:2px;"></span> Has data</span>
        <span style="font-size: 11px; color: #9ca3af;"><span style="display:inline-block;width:10px;height:10px;background:#e5e7eb;border-radius:2px;"></span> No data</span>
      </div>
    </div>
  </div>
</div>

<!-- Table Section -->
<div style="background: white; padding: 25px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
  <h3 style="margin: 0 0 20px 0; color: #003d5c; display: flex; align-items: center; gap: 10px; font-size: 20px;">
    <i class="fas fa-user-shield" style="color: #f59e0b; font-size: 24px;"></i>
    DSM Monitoring Data
  </h3>
  
  <table id="dsmTable" class="modern-table">
    <thead>
      <tr>
        <th>Time</th>
        <th>Vehicle</th>
        <th>LPN</th>
        <th>Alarm Type</th>
        <th>Speed</th>
        <th>Location</th>
        <th>Files</th>
        <th>Action</th>
      </tr>
    </thead>
  </table>
</div>

<!-- File Preview Modal -->
<div id="filePreviewModal" class="file-preview-modal">
  <div class="file-preview-content">
    <div class="file-preview-header">
      <div class="file-preview-title">
        <i class="fas fa-images"></i>
        <span>Alarm Files Preview</span>
      </div>
      <button class="file-preview-close" onclick="closeFilePreview()">&times;</button>
    </div>
    <div class="file-preview-body">
      <div class="alarm-info">
        <div class="alarm-info-item">
          <div class="alarm-info-label">Vehicle</div>
          <div class="alarm-info-value" id="previewVehicleName">-</div>
        </div>
        <div class="alarm-info-item">
          <div class="alarm-info-label">Alarm Type</div>
          <div class="alarm-info-value" id="previewAlarmType">-</div>
        </div>
        <div class="alarm-info-item">
          <div class="alarm-info-label">Time</div>
          <div class="alarm-info-value" id="previewEventTime">-</div>
        </div>
        <div class="alarm-info-item">
          <div class="alarm-info-label">Speed</div>
          <div class="alarm-info-value" id="previewSpeed">-</div>
        </div>
        <div class="alarm-info-item">
          <div class="alarm-info-label">Location</div>
          <div class="alarm-info-value" id="previewLocation">-</div>
        </div>
      </div>

      <div class="files-section-title">
        <i class="fas fa-photo-video"></i>
        Media Files
      </div>
      <div id="filesGrid" class="files-grid"></div>
    </div>
  </div>
</div>

<!-- Fullscreen File Viewer -->
<div id="fileViewerFullscreen" class="file-viewer-fullscreen">
  <span class="file-viewer-close" onclick="closeFileViewer()">&times;</span>
  <div id="fileViewerContent" class="file-viewer-content"></div>
</div>

<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
<script src="/js/datatable-helper.js"></script>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
  let dsmTable;
  let startDatePicker, endDatePicker;
  let availableDates = new Set();

  $(document).ready(function() {
    startDatePicker = flatpickr('#startDate', {
      enableTime: true, dateFormat: 'Y-m-d H:i', time_24hr: true,
      onDayCreate: function(dObj, dStr, fp, dayElem) {
        const dateStr = dayElem.dateObj.toISOString().split('T')[0];
        if (availableDates.has(dateStr)) { dayElem.style.background = '#dcfce7'; dayElem.style.borderRadius = '50%'; }
      }
    });
    endDatePicker = flatpickr('#endDate', {
      enableTime: true, dateFormat: 'Y-m-d H:i', time_24hr: true, defaultDate: new Date(),
      onDayCreate: function(dObj, dStr, fp, dayElem) {
        const dateStr = dayElem.dateObj.toISOString().split('T')[0];
        if (availableDates.has(dateStr)) { dayElem.style.background = '#dcfce7'; dayElem.style.borderRadius = '50%'; }
      }
    });
    initDataTable();
  });

  function onTimeRangeChange() {
    const val = $('#hoursFilter').val();
    if (val === 'custom') { $('#customDateRange').css('display', 'flex'); loadDataAvailability(); }
    else { $('#customDateRange').hide(); $('#dataAvailability').hide(); }
  }

  function onVehicleChange() {
    if ($('#hoursFilter').val() === 'custom') loadDataAvailability();
  }

  async function loadDataAvailability() {
    const vehicle = $('#vehicleFilter').val() || 'all';
    try {
      const resp = await fetch(`/api/data-availability?vehicle=${vehicle}&type=dsm`);
      const data = await resp.json();
      availableDates = new Set(data.dates.map(d => d.date));
      if (startDatePicker) startDatePicker.redraw();
      if (endDatePicker) endDatePicker.redraw();
      const container = document.getElementById('availabilityGrid');
      const infoEl = document.getElementById('dataRangeInfo');
      container.innerHTML = '';
      if (data.range.earliest) {
        const earliest = new Date(data.range.earliest);
        const latest = new Date(data.range.latest);
        infoEl.textContent = `${earliest.toLocaleDateString('id-ID')} — ${latest.toLocaleDateString('id-ID')} (${data.range.total.toLocaleString()} records)`;
        const today = new Date();
        const dateMap = new Map(data.dates.map(d => [d.date, d.count]));
        for (let i = 89; i >= 0; i--) {
          const d = new Date(today); d.setDate(d.getDate() - i);
          const dateStr = d.toISOString().split('T')[0];
          const count = dateMap.get(dateStr) || 0;
          const cell = document.createElement('div');
          cell.title = `${dateStr}: ${count} events`;
          cell.style.cssText = `width:8px;height:8px;border-radius:2px;cursor:pointer;background:${count > 0 ? (count > 50 ? '#16a34a' : count > 10 ? '#4ade80' : '#bbf7d0') : '#e5e7eb'}`;
          cell.onclick = () => { if (count > 0) { startDatePicker.setDate(dateStr + ' 00:00'); endDatePicker.setDate(dateStr + ' 23:59'); } };
          container.appendChild(cell);
        }
      } else { infoEl.textContent = 'No data found'; }
      document.getElementById('dataAvailability').style.display = 'block';
    } catch (err) { console.error('Error loading availability:', err); }
  }

  function initDataTable() {
    if (dsmTable) {
      dsmTable.destroy();
    }
    
    const vehicle = $('#vehicleFilter').val() || 'all';
    const hoursVal = $('#hoursFilter').val();
    const isCustom = hoursVal === 'custom';
    const startDate = isCustom ? $('#startDate').val() : null;
    const endDate = isCustom ? $('#endDate').val() : null;
    const hours = isCustom ? null : hoursVal;
    
    dsmTable = $('#dsmTable').DataTable({
      processing: true,
      serverSide: true,
      ajax: {
        url: '/api/dsm/datatable',
        data: function(d) {
          d.vehicle = vehicle;
          if (isCustom && startDate && endDate) {
            d.startDate = new Date(startDate).toISOString();
            d.endDate = new Date(endDate).toISOString();
          } else {
            d.hours = hours || 24;
          }
        }
      },
      columns: [
        { 
          data: 'event_time',
          render: function(data) {
            return new Date(data).toLocaleString('id-ID', {
              year: 'numeric',
              month: '2-digit',
              day: '2-digit',
              hour: '2-digit',
              minute: '2-digit',
              second: '2-digit'
            });
          }
        },
        { 
          data: 'vehicle_name',
          render: function(data) {
            return `<strong>${data}</strong>`;
          }
        },
        { data: 'lpn' },
        { 
          data: 'alarm_type',
          render: function(data) {
            return `<span class="badge badge-dsm">${data}</span>`;
          }
        },
        { 
          data: 'speed',
          render: function(data) {
            return `<span class="speed-badge">${data}</span> <small>km/h</small>`;
          }
        },
        { 
          data: null,
          render: function(data) {
            return `<a href="https://www.google.com/maps?q=${data.lat},${data.lng}" target="_blank" class="location-link">
              <i class="fas fa-map-marker-alt"></i> ${data.lat.toFixed(4)}, ${data.lng.toFixed(4)}
            </a>`;
          }
        },
        { 
          data: 'files',
          orderable: false,
          render: function(data) {
            if (!data || data.length === 0) {
              return '<span class="badge badge-no-files"><i class="fas fa-folder-open"></i> No files</span>';
            }
            return `<span class="badge badge-files"><i class="fas fa-paperclip"></i> ${data.length} file(s)</span>`;
          }
        },
        {
          data: null,
          orderable: false,
          render: function(data, type, row) {
            const hasFiles = row.files && row.files.length > 0;
            const rowData = JSON.stringify(row).replace(/'/g, "\\'");
            return `
              <button class="btn-view-files" onclick='viewAlarmFiles(${rowData})' ${hasFiles ? '' : 'disabled'}>
                <i class="fas fa-eye"></i> View
              </button>
            `;
          }
        }
      ],
      order: [[0, 'desc']],
      pageLength: 25,
      lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
      language: {
        processing: '<i class="fas fa-spinner fa-spin"></i> Loading...',
        search: "Search:",
        lengthMenu: "Show _MENU_ entries",
        info: "Showing _START_ to _END_ of _TOTAL_ alarms",
        infoEmpty: "No alarms found",
        infoFiltered: "(filtered from _MAX_ total)",
        paginate: {
          first: "First",
          last: "Last",
          next: "Next",
          previous: "Previous"
        }
      }
    });
  }

  function applyFilter() {
    initDataTable();
  }

  function refreshTable() {
    if (dsmTable) {
      dsmTable.ajax.reload();
    }
  }

  function exportData() {
    const vehicle = $('#vehicleFilter').val() || 'all';
    const hoursVal = $('#hoursFilter').val();
    if (hoursVal === 'custom') {
      const s = new Date($('#startDate').val()).toISOString();
      const e = new Date($('#endDate').val()).toISOString();
      window.open(`/api/dsm?vehicle=${vehicle}&startDate=${s}&endDate=${e}&limit=10000`, '_blank');
    } else {
      window.open(`/api/dsm?vehicle=${vehicle}&hours=${hoursVal}&limit=10000`, '_blank');
    }
  }

  function viewAlarmFiles(alarmData) {
    showFilePreview(alarmData);
  }
</script>
