<link rel="stylesheet" href="/css/dashboard.css" />

<!-- Enhanced Filter Section -->
<div class="filter-container">
  <div class="filter-header">
    <div class="filter-title">
      <i class="fas fa-filter"></i>
      <span>Data Filter</span>
    </div>
    <button class="btn-reset" onclick="resetFilters()" title="Reset to default">
      <i class="fas fa-redo"></i> Reset
    </button>
  </div>

  <div class="filter-body">
    <!-- Quick Select Presets -->
    <div class="filter-section">
      <label class="filter-label">Quick Select</label>
      <div class="preset-buttons">
        <button class="preset-btn active" data-hours="1" onclick="selectPreset(1)">
          <i class="fas fa-clock"></i> Last Hour
        </button>
        <button class="preset-btn" data-hours="3" onclick="selectPreset(3)">
          <i class="fas fa-clock"></i> 3 Hours
        </button>
        <button class="preset-btn" data-hours="5" onclick="selectPreset(5)">
          <i class="fas fa-clock"></i> 5 Hours
        </button>
        <button class="preset-btn" data-hours="24" onclick="selectPreset(24)">
          <i class="fas fa-calendar-day"></i> 24 Hours
        </button>
        <button class="preset-btn" data-hours="168" onclick="selectPreset(168)">
          <i class="fas fa-calendar-week"></i> 7 Days
        </button>
        <button class="preset-btn" data-custom="true" onclick="toggleCustomRange()">
          <i class="fas fa-calendar-alt"></i> Custom Range
        </button>
      </div>
    </div>

    <!-- Custom Date Range (Hidden by default) -->
    <div class="filter-section custom-range-section" id="customRangeSection" style="display: none">
      <label class="filter-label">Custom Date Range</label>
      <div class="date-range-inputs">
        <div class="date-input-group">
          <label class="input-label"> <i class="fas fa-calendar-check"></i> Start Date & Time </label>
          <input type="datetime-local" id="safetyStart" class="date-input" />
        </div>
        <div class="date-range-separator">
          <i class="fas fa-arrow-right"></i>
        </div>
        <div class="date-input-group">
          <label class="input-label"> <i class="fas fa-calendar-check"></i> End Date & Time </label>
          <input type="datetime-local" id="safetyEnd" class="date-input" />
        </div>
      </div>
    </div>

    <!-- Apply Button -->
    <div class="filter-actions">
      <button class="btn-apply" onclick="applySafetyFilter()"><i class="fas fa-check-circle"></i> Apply Filter</button>
      <div class="filter-info" id="filterInfo">
        <i class="fas fa-info-circle"></i>
        <span id="filterStatusText">Showing: Last 1 hour</span>
      </div>
    </div>
  </div>
</div>

<!-- Safety Score Section -->
<div class="safety-score-section">
  <div class="score-card" id="fleetScoreCard">
    <div class="score-header">
      <div class="score-title">Fleet Safety Score</div>
      <div class="score-icon" style="background: #e0f2fe; color: #0066a1">
        <i class="fas fa-shield-alt"></i>
      </div>
    </div>
    <div class="score-display">
      <div class="score-value" id="fleetScoreValue">--</div>
      <div class="score-grade" id="fleetScoreGrade">-</div>
    </div>
    <div class="score-label" id="fleetScoreLabel">Loading...</div>
    <div class="score-details">
      <div class="score-detail-item">
        <span class="score-detail-label">Total Alarms</span>
        <span class="score-detail-value" id="fleetTotalAlarms">--</span>
      </div>
      <div class="score-detail-item">
        <span class="score-detail-label">Critical</span>
        <span class="score-detail-value" id="fleetCritical" style="color: #ef4444">--</span>
      </div>
      <div class="score-detail-item">
        <span class="score-detail-label">ADAS</span>
        <span class="score-detail-value" id="fleetADAS">--</span>
      </div>
      <div class="score-detail-item">
        <span class="score-detail-label">DSM</span>
        <span class="score-detail-value" id="fleetDSM">--</span>
      </div>
    </div>
  </div>

  <div class="score-card">
    <div class="score-header">
      <div class="score-title">Active Vehicles</div>
      <div class="score-icon" style="background: #dcfce7; color: #22c55e">
        <i class="fas fa-truck"></i>
      </div>
    </div>
    <div class="score-display">
      <div class="score-value" id="activeVehicles">--</div>
    </div>
    <div class="score-label">Fleet Currently Tracked</div>
  </div>

  <div class="score-card">
    <div class="score-header">
      <div class="score-title">ADAS Events (1h)</div>
      <div class="score-icon" style="background: #fef3c7; color: #f59e0b">
        <i class="fas fa-car-crash"></i>
      </div>
    </div>
    <div class="score-display">
      <div class="score-value" id="adasCount" style="color: #f59e0b">--</div>
    </div>
    <div class="score-label">Collision & Lane Warnings</div>
  </div>

  <div class="score-card">
    <div class="score-header">
      <div class="score-title">DSM Events (1h)</div>
      <div class="score-icon" style="background: #dbeafe; color: #3b82f6">
        <i class="fas fa-user-shield"></i>
      </div>
    </div>
    <div class="score-display">
      <div class="score-value" id="dsmCount" style="color: #3b82f6">--</div>
    </div>
    <div class="score-label">Driver Monitoring Alerts</div>
  </div>
</div>

<!-- Risky Vehicles Section -->
<div class="risky-vehicles-card" id="riskyVehiclesCard">
  <div class="risky-vehicles-header">
    <div class="risky-vehicles-title"><i class="fas fa-exclamation-triangle"></i> Top 5 Risky Vehicles (Last Hour)</div>
    <button class="btn-icon" onclick="loadSafetyScores()" title="Refresh">
      <i class="fas fa-sync-alt"></i>
    </button>
  </div>
  <div id="riskyVehiclesList">
    <div style="text-align: center; padding: 20px; color: #999"><i class="fas fa-spinner fa-spin"></i> Loading...</div>
  </div>
</div>

<!-- Map Section -->
<div class="map-section">
  <div class="map-header">
    <div class="map-title"><i class="fas fa-map-marked-alt"></i> Fleet Summary</div>
    <div class="map-legend">
      <div class="legend-item">
        <span class="legend-dot moving"></span>
        <span>Moving</span>
      </div>
      <div class="legend-item">
        <span class="legend-dot stopped"></span>
        <span>Stopped</span>
      </div>
      <div class="legend-item">
        <span class="legend-dot idle"></span>
        <span>Idle</span>
      </div>
    </div>
  </div>

  <div style="position: relative">
    <div id="map"></div>
    <div class="map-controls">
      <label class="control-item">
        <input type="checkbox" id="toggleADAS" checked onchange="toggleAlarmType('ADAS')" />
        <span class="control-label">
          <div class="control-marker" style="background: #ef4444; clip-path: polygon(50% 0%, 100% 100%, 0% 100%)"></div>
          ADAS Alarms
        </span>
      </label>
      <label class="control-item">
        <input type="checkbox" id="toggleDSM" checked onchange="toggleAlarmType('DSM')" />
        <span class="control-label">
          <div class="control-marker" style="background: #f59e0b; border-radius: 50%"></div>
          DSM Alarms
        </span>
      </label>
    </div>
  </div>
</div>

<!-- Fleet Table Section -->
<div class="fleet-table-section">
  <div class="table-header">
    <div class="table-title"><i class="fas fa-table"></i> Fleet Summary</div>
    <div class="table-actions">
      <button class="btn-icon" onclick="refreshData()"><i class="fas fa-sync-alt"></i> Refresh</button>
    </div>
  </div>
  <div class="table-responsive">
    <table>
      <thead>
        <tr>
          <th>Vehicle</th>
          <th>Avg Speed</th>
          <th>Distance Traveled</th>
          <th>GPS Quality</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="fleetTableBody">
        <tr>
          <td colspan="5" style="text-align: center; padding: 40px">
            <i class="fas fa-spinner fa-spin"></i> Loading summary...
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>


<script src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>&callback=initMap" async defer></script>
<script src="/js/dashboard.js"></script>
